{
  "name": "ask-doc",
  "version": "1.0.0",
  "description": "Local CLI tool to ingest docs and manage configurations dynamically via prompt command get/set operations",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ask-doc": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "start": "clear && node dist/index.js",
    "download-models": "clear && npm run build && node dist/scripts/downloadModels.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.0",
    "@lancedb/lancedb": "^0.11.0",
    "asciichart": "^1.5.25",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "csv-parse": "^7.0.0",
    "fs-extra": "^11.2.0",
    "mammoth": "^1.8.0",
    "node-cache": "^5.1.2",
    "onnxruntime-node": "1.20.1",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "pino": "^9.1.0",
    "pino-pretty": "^13.0.0",
    "systeminformation": "^5.23.4",
    "tesseract.js": "^5.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/asciichart": "^1.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@huggingface/transformers": {
      "onnxruntime-node": "1.20.1"
    }
  }
}

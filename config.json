{
  "app_name": "ask-doc",
  "version": "2.0.0",
  "models": [
    {
      "type": "embedding",
      "id": "xenova-minilm",
      "name": "Xenova/all-MiniLM-L6-v2",
      "local_path": "./model/embeddings/all-MiniLM-L6-v2",
      "active": true
    }
  ],
  "storage": [
    {
      "classification": "models_root",
      "path": "./model"
    },
    {
      "classification": "vector_store_root",
      "path": "./vector-store"
    },
    {
      "classification": "vector_store_type",
      "value": "file" // Options: "lancedb", "file"
    }
  ],
  "ingestion": [
    {
      "classification": "text_processing",
      "chunk_size": 1000,
      "chunk_overlap": 100,
      "source_path": "./docs/src",
      "supported_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx",
        ".xlsx",
        ".csv"
      ],
      "tagging_categories": [
        { "tag": "technical", "keywords": ["code", "api", "function", "class", "implementation", "service", "database"] },
        { "tag": "documentation", "keywords": ["guide", "readme", "tutorial", "instruction", "overview", "getting started"] },
        { "tag": "legal", "keywords": ["license", "copyright", "privacy", "agreement", "terms", "compliance"] },
        { "tag": "project-management", "keywords": ["roadmap", "sprint", "milestone", "deadline", "task", "kanban"] },
        { "tag": "finance", "keywords": ["invoice", "billing", "payment", "budget", "expense", "tax", "ledger", "financial"] },
        { "tag": "marketing", "keywords": ["campaign", "strategy", "advertisement", "analytics", "engagement", "branding", "leads"] },
        { "tag": "research", "keywords": ["abstract", "study", "experiment", "methodology", "results", "data", "hypothesis", "conclusion"] },
        { "tag": "medical", "keywords": ["patient", "diagnosis", "treatment", "symptoms", "prescription", "clinical", "health"] },
        { "tag": "human-resources", "keywords": ["resume", "hiring", "recruitment", "benefits", "payroll", "employee", "onboarding"] }
      ],
      "tagging_relevance_threshold": 0.5, 
      "tagging_top_k": 3,
      "tag_timeout_ms": 30000 
    }
  ],
  "logging": {
    "level": "info",
    "file_path": "./logs/app.log",
    "enabled": true
  },
  "security": {
    "max_file_size_mb": 150,
    "max_chunks_per_minute": 1000,
    "allow_directory_traversal": false,
    "dynamic_throttling_enabled": true,
    "target_cpu_load": 80,
    "max_cpu_temp": 75
  },
  "caching": {
    "enabled": true,
    "embedding_cache_path": "./vector-store/embedding_cache.json"
  }
}